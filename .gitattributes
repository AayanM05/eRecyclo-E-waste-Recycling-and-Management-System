# ============================================================
# E-RECYCLO — GitHub Linguist Language Statistics Override
# ============================================================

# Ensure Python gets 100% priority in the language statistics bar
*.py linguist-detectable=true

# Mark all templates, static assets, and client scripts as vendored
# so they are excluded from the codebase language statistics calculation
*.html linguist-vendored
*.css linguist-vendored
*.js linguist-vendored
*.scss linguist-vendored

# Exclude static/media folders entirely from language bar metrics
static/** linguist-vendored
staticfiles/** linguist-vendored
media/** linguist-vendored
